# Hermes -> Ares connector
HERMES_RUNTIME_API_BASE_URL=http://127.0.0.1:8000
HERMES_RUNTIME_API_KEY=<local-runtime-api-key>
RUNTIME_API_BASE_URL=http://127.0.0.1:8000

# Ares runtime
RUNTIME_API_KEY=<local-runtime-api-key>
RUNTIME_DOCS_ENABLED=false
RUNTIME_ACTOR_HEADER_OVERRIDES_ENABLED=false
PROVIDER_WEBHOOK_SIGNATURES_REQUIRED=true
PROVIDER_LIVE_SENDS_ENABLED=false
CONTROL_PLANE_BACKEND=memory
MARKETING_BACKEND=memory
# Local-only default is memory. Production no-send probate autopilot must override to supabase.
LEAD_MACHINE_BACKEND=memory
SITE_EVENTS_BACKEND=memory
LEAD_MACHINE_BUSINESS_ID=limitless
LEAD_MACHINE_ENVIRONMENT=prod
LEAD_MACHINE_SOURCE_RUNS_STATE_PATH=/var/lib/ares/lead-machine/source-runs.json
LEAD_MACHINE_ARTIFACT_ROOT=/var/lib/ares/lead-machine/artifacts
LEAD_MACHINE_LIVE_SOURCE_CALLS_ENABLED=true
LEAD_MACHINE_SCHEDULED_LIVE_SOURCE_CALLS_ENABLED=true
LEAD_MACHINE_SOURCE_ADAPTER_PREVIEW_ENABLED=false
LEAD_MACHINE_LIVE_CAD_CALLS_ENABLED=true
LEAD_MACHINE_LIVE_TAX_CALLS_ENABLED=true
LEAD_MACHINE_LIVE_LAND_RECORD_CALLS_ENABLED=true
LEAD_MACHINE_LIVE_CASE_DETAIL_CALLS_ENABLED=true
LEAD_MACHINE_SCHEDULED_LIVE_ENRICHMENT_CALLS_ENABLED=true
LEAD_MACHINE_SCHEDULED_LIVE_CASE_DETAIL_CALLS_ENABLED=true

# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DIRECT_CONNECTION_STRING=
SUPABASE_SECRET_KEY=
LEAD_MACHINE_SUPABASE_URL=
LEAD_MACHINE_SUPABASE_SERVICE_ROLE_KEY=

# Trigger.dev
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev
# Explicitly enable only after Trigger prod env points at the live Ares runtime.
ARES_TRIGGER_SCHEDULES_ENABLED=false
TRIGGER_NON_BOOKER_CHECK_TASK_ID=marketing-check-submitted-lead-booking
TRIGGER_APPOINTMENT_REMINDER_TASK_ID=marketing-send-appointment-reminder
MARKETING_APPOINTMENT_REMINDERS_ENABLED=true

