# Keep Docker/build contexts from accidentally carrying local secrets or heavy artifacts.
.git/
.worktrees/
.vercel/
.env
.env.*
*.env
!.env.example
*.pem
*.key
*.crt

# Python/local caches
.venv/
venv/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pyc
*.pyo

# Node/build outputs
node_modules/
apps/mission-control/node_modules/
trigger/node_modules/
dist/
build/
coverage/
*.tsbuildinfo

# Local/editor artifacts
.DS_Store
scripts/ralph/last-message.txt
